{
  "name": "arbiter",
  "version": "0.1.0",
  "description": "Cross-platform prediction market arbitrage system",
  "type": "module",
  "main": "dist/cli.js",
  "scripts": {
    "start": "node dist/cli.js",
    "start:dev": "npx tsx src/cli.ts",
    "build": "tsc",
    "dashboard:api": "./scripts/run-dashboard-api.sh",
    "dashboard:demo": "./scripts/run-dashboard-demo.sh",
    "dashboard:dry": "./scripts/run-dashboard-dry.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:python": "python3 -m pytest -q arbiter",
    "verify:quick": "./scripts/quick-check.sh",
    "verify:ui": "./scripts/ui-smoke.sh",
    "verify:full": "./scripts/quick-check.sh && ./scripts/ui-smoke.sh"
  },
  "dependencies": {
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "vitest": "^4.1.4"
  }
}
