# ARBITER — Environment Variables
# Copy to .env and fill in your values

# ── Core ────────────────────────────────────────────────────────────────────
# Set to 'false' ONLY when all credential flows are tested and verified.
# When unset or 'true', all trading is simulated — no real orders placed.
DRY_RUN=true

# ── Postgres ────────────────────────────────────────────────────────────────
# Full connection string. Can also use individual PG_* vars.
DATABASE_URL=postgresql://arbiter:arbiter_secret@localhost:5432/arbiter_dev
# Individual overrides (used if DATABASE_URL not set):
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=arbiter
# PG_PASSWORD=arbiter_secret
# PG_DATABASE=arbiter_dev

# ── Redis (optional — in-memory fallback if not set) ───────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kalshi ─────────────────────────────────────────────────────────────────
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./keys/kalshi_private.pem

# ── Polymarket ──────────────────────────────────────────────────────────────
POLY_PRIVATE_KEY=

# ── Telegram Alerts ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── UI Auth (operator desk) ────────────────────────────────────────────────
# Set a random secret for the operator dashboard session cookie.
# Generate one with: openssl rand -hex 32
UI_SESSION_SECRET=change_me_use_openssl_rand_hex_32

# ── Alert thresholds ─────────────────────────────────────────────────────────
# Minimum $ profit per arb before taking it (net of fees)
MIN_EDGE_CENTS=5
# Maximum exposure per canonical market in $
MAX_POSITION_USD=100
# Maximum total exposure across all markets in $
MAX_TOTAL_EXPOSURE=500

# ── Sentry / Observability ─────────────────────────────────────────────────
# Leave SENTRY_DSN unset to disable error tracking (sentry-sdk becomes a no-op).
# Get a DSN from https://sentry.io → Settings → Projects → [project] → Client Keys (DSN).
SENTRY_DSN=
ARBITER_ENV=development
ARBITER_RELEASE=unknown
