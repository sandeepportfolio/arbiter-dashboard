# ARBITER -- Phase 5 LIVE TRADING environment
# COPY TO .env.production AND FILL IN REAL VALUES. Source with:
#   set -a; source .env.production; set +a
# before running `python -m arbiter.main --live`.
#
# CRITICAL SAFETY NOTES:
# - This file holds REAL MONEY credentials. Never commit, never share.
#   `.env.production` is git-ignored; the template is the only committed artifact.
# - DRY_RUN=false means orders are PLACED AGAINST REAL PLATFORMS.
# - PHASE5_MAX_ORDER_USD=10 caps each order at $10 notional (belt above position sizing).
# - Run `python -m arbiter.live.preflight` before setting DRY_RUN=false. ALL 15 items must pass.

# ── Core ────────────────────────────────────────────────────────────────────
DRY_RUN=false

# ── Postgres (arbiter_live — separate from dev and sandbox) ─────────────────
DATABASE_URL=postgresql://arbiter:arbiter_secret@localhost:5432/arbiter_live

# ── Kalshi (PRODUCTION — separate key from demo) ────────────────────────────
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2
KALSHI_API_KEY_ID=<production-api-key-id-from-kalshi.com>
KALSHI_PRIVATE_KEY_PATH=./keys/kalshi_private.pem

# ── Polymarket (PRODUCTION — real wallet, <=$50 USDC) ───────────────────────
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLY_PRIVATE_KEY=<REAL-WALLET-PRIVATE-KEY>
POLY_SIGNATURE_TYPE=2
POLY_FUNDER=<funder-address>

# ── Phase 5 hard-lock ($10 cap on every order notional) ─────────────────────
# Adapter-layer belt: PHASE5_MAX_ORDER_USD is enforced in
# PolymarketAdapter.place_fok, KalshiAdapter.place_fok, and
# KalshiAdapter.place_resting_limit BEFORE any HTTP/CLOB call. When
# notional = qty * price > cap, adapter returns _failed_order without any
# network side effect. Unparseable value = 0.0 cap (rejects everything).
PHASE5_MAX_ORDER_USD=10

# ── Phase 4 hard-lock (typically UNSET in production — Phase 5 is stricter) ──
# W-2 polarity fix: preflight check #9 treats PHASE4_MAX_ORDER_USD absence as
# EXPECTED in production (pass, not-blocking). It BLOCKS only when both caps
# are set AND PHASE4 < PHASE5 (the unsafe inversion where Phase 4's tighter
# cap would reject below the Phase 5 belt). If you want belt-and-suspenders
# with both caps active, set PHASE4 >= PHASE5 (e.g. PHASE4=50 PHASE5=10) so
# Phase 5 is the first belt to reject.
# PHASE4_MAX_ORDER_USD=    # Leave unset (or set to a value >= PHASE5_MAX_ORDER_USD).

# ── Position sizing override (B-5: scanner-level belt above adapter cap) ────
# Without this, scanner sizes at default max_position_usd=100 and every
# trade hits the $10 adapter hard-lock. MUST be <= PHASE5_MAX_ORDER_USD.
MAX_POSITION_USD=10

# ── B-1 Q6: Bootstrap-mode readiness override (chicken-and-egg resolution) ──
# The readiness _check_profitability gate blocks on 'collecting_evidence'
# with zero live executions. This env var lets the FIRST N live trades
# bypass that gate; once N trades complete, the gate re-engages normally.
# Valid range: 1..5. Unset = existing behavior (Phase 4 + dev unchanged).
PHASE5_BOOTSTRAP_TRADES=1

# ── Telegram (required for Phase 5 alerting) ────────────────────────────────
TELEGRAM_BOT_TOKEN=<bot-token>
TELEGRAM_CHAT_ID=<chat-id>

# ── Preflight acknowledgment env vars ───────────────────────────────────────
# Check #13: set to ACKNOWLEDGED after verifying Polymarket April 2026
# migration compatibility (see arbiter/live/README.md Troubleshooting).
POLYMARKET_MIGRATION_ACK=
# Check #15: set to ACKNOWLEDGED after reading arbiter/live/README.md in full.
OPERATOR_RUNBOOK_ACK=

# ── Observability ───────────────────────────────────────────────────────────
ARBITER_ENV=production
ARBITER_RELEASE=phase5-first-live-trade
SENTRY_DSN=<optional-sentry-dsn>

# ── UI Auth (dashboard HMAC-SHA256 session tokens) ──────────────────────────
UI_SESSION_SECRET=<openssl-rand-hex-32>

# ── Phase 6 auto-execute (DEFAULT DISABLED) ─────────────────────────────────
# AUTO_EXECUTE_ENABLED=true flips AutoExecutor from no-op to live execution.
# Keep FALSE until the first supervised live trade (Phase 5 Plan 05-02) has
# passed reconcile. Then flip to true and watch /api/metrics + /ops dashboard.
AUTO_EXECUTE_ENABLED=false

# Per-leg notional cap enforced by AutoExecutor BEFORE engine.execute_opportunity.
# Independent of PHASE4/5 adapter-layer hard-locks (defense in depth).
MAX_POSITION_USD=10

# Initial rollout cap. Unset or =0 => no cap (full auto mode).
# For the first live-auto deployment, set to 5 and watch each trade finish.
# PHASE5_BOOTSTRAP_TRADES is already defined above — the AutoExecutor reads
# the same env var so it caps both the preflight-gated manual live trades
# AND the scanner-fed auto trades under the same budget.
