# ══════════════════════════════════════════════════════════════════════════════
# ARBITER — Production (LIVE TRADING) environment template
# ══════════════════════════════════════════════════════════════════════════════
#
# WHAT THIS FILE IS
#   The shape of .env.production — the real file that holds live-trading
#   credentials. Copy, populate, never commit.
#
#     cp .env.production.template .env.production
#     chmod 600 .env.production
#
# SECURITY RULES (for humans and AI agents)
#   - .env.production is git-ignored. Never commit it.
#   - ./keys/*.pem is git-ignored. Never commit it.
#   - File permissions: 0600 (owner read/write only).
#   - If you leak a private key: ARM kill-switch immediately, revoke the key
#     on the platform, withdraw funds, rotate.
#
# HOW TO USE
#   1. Fill in every <placeholder> below. Each has a HOW TO OBTAIN block.
#   2. Run: set -a; source .env.production; set +a
#   3. Run: python scripts/setup/validate_env.py    (shape + sanity check)
#   4. Run: ./scripts/setup/go_live.sh              (full preflight bring-up)
#
# ══════════════════════════════════════════════════════════════════════════════


# ── Core ──────────────────────────────────────────────────────────────────────
# DRY_RUN=false means real money moves. Keep this false ONLY after you have
# validated every credential + run the 15-item preflight clean.
DRY_RUN=false


# ── Postgres ──────────────────────────────────────────────────────────────────
# With docker-compose.prod.yml, DATABASE_URL is overridden to point at
# arbiter-postgres-prod inside the compose network. The value here is the
# fallback for bare-metal/systemd installs. Change <strong-password> below
# and also update PG_PASSWORD in the compose env.
#
# HOW TO OBTAIN: generate a random password:
#   openssl rand -base64 24
#
DATABASE_URL=postgresql://arbiter:<strong-password>@localhost:5432/arbiter_live
PG_USER=arbiter
PG_PASSWORD=<strong-password>


# ── Kalshi (PRODUCTION — NOT demo) ────────────────────────────────────────────
# These values MUST point at prod (api.elections.kalshi.com), NOT
# demo-api.kalshi.co. validate_env.py rejects "demo" in the base URL.
#
# HOW TO OBTAIN:
#   1. Open https://kalshi.com (a browser, not curl).
#   2. Log in; complete KYC if required.
#   3. Fund account via Account → Deposit (>= $100 recommended).
#   4. Navigate Account → API Keys → Create Key.
#   5. Copy the Key ID shown → paste as KALSHI_API_KEY_ID below.
#   6. Download the RSA private key (shown ONCE). Save it at the path below
#      and `chmod 600 ./keys/kalshi_private.pem`.
#
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2
KALSHI_API_KEY_ID=<production-api-key-id-from-kalshi.com>
KALSHI_PRIVATE_KEY_PATH=./keys/kalshi_private.pem


# ── Polymarket (PRODUCTION — real Polygon wallet + USDC) ──────────────────────
# HOW TO OBTAIN:
#   1. Create a FRESH MetaMask account (new seed, NOT your personal wallet).
#      This wallet should only ever hold trading funds.
#   2. Bridge 20–50 USDC to the wallet on Polygon mainnet (chain id 137).
#      Route options:
#        - Coinbase → Send → Polygon network → USDC
#        - Bridge tools: Across, Stargate, LI.FI
#   3. Open https://polymarket.com, connect the wallet, complete deposit
#      flow to move USDC into Polymarket trading balance.
#   4. In MetaMask: Account Details → Show Private Key.
#      Paste 64-hex-char (no 0x prefix) into POLY_PRIVATE_KEY below.
#   5. Copy the wallet address (starts with 0x, 40 hex chars) → POLY_FUNDER.
#
# POLY_SIGNATURE_TYPE: 0 for direct EOA, 2 for proxy wallet (default for
# new Polymarket users). If CLOB auth fails, flip between these two.
#
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLY_PRIVATE_KEY=<64-hex-char-Polygon-wallet-key-no-0x-prefix>
POLY_SIGNATURE_TYPE=2
POLY_FUNDER=<0x-wallet-address-40-hex-chars>
POLYGON_RPC_URL=https://polygon-rpc.com


# ── Safety caps — all three layers (defense in depth) ────────────────────────
# These are enforced independently. Losing any one still leaves two belts.
#
# PHASE5_MAX_ORDER_USD — adapter-layer hard-lock. Every order notional is
# checked BEFORE any HTTP/CLOB call. Exceeding the cap returns _failed_order
# with zero network side effect. Set to the dollar amount you are willing
# to lose per trade.
PHASE5_MAX_ORDER_USD=10

# PHASE4_MAX_ORDER_USD — legacy hard-lock. Leave commented unless you want
# belt-and-suspenders. If set, PHASE4 must be >= PHASE5 (else PHASE4 would
# reject below the Phase 5 belt, which is the unsafe inversion).
# PHASE4_MAX_ORDER_USD=

# MAX_POSITION_USD — AutoExecutor position cap. The max-leg notional is
# checked before calling engine.execute_opportunity. Must be <= PHASE5 cap.
MAX_POSITION_USD=10

# PHASE5_BOOTSTRAP_TRADES — rollout cap. For the first N auto-trades the
# system logs extra detail; after N, AutoExecutor refuses until you flip
# this to a higher value or remove it.
# Valid range: 1..5 for the initial rollout; unset or 0 = no cap.
PHASE5_BOOTSTRAP_TRADES=5


# ── Auto-execute toggle (DEFAULT OFF — do not flip until after first trade) ──
# When false: AutoExecutor consumes opportunities but NEVER calls
# engine.execute_opportunity. Safe default.
# When true: AutoExecutor calls engine.execute_opportunity subject to the
# other 6 policy gates.
# Flip ONLY after the first supervised live trade (GOLIVE.md §7) passes.
AUTO_EXECUTE_ENABLED=false


# ── Telegram alerts (required for Phase 5 preflight) ──────────────────────────
# HOW TO OBTAIN:
#   1. In Telegram, message @BotFather. Send: /newbot
#   2. Pick a name + username. @BotFather replies with a token (~45 chars).
#      Paste it as TELEGRAM_BOT_TOKEN below.
#   3. In Telegram, message @userinfobot. Reply contains your numeric chat id.
#      Paste it as TELEGRAM_CHAT_ID below.
#   4. IMPORTANT: send any message to your bot (start a chat) BEFORE running
#      the dry-test. Telegram won't deliver bot messages to a chat that has
#      never initiated.
#
# Verify with:
#   python scripts/setup/check_telegram.py
#
TELEGRAM_BOT_TOKEN=<45-char-bot-token-from-@BotFather>
TELEGRAM_CHAT_ID=<numeric-chat-id-from-@userinfobot>


# ── Preflight acknowledgments ─────────────────────────────────────────────────
# These gate the 15-item preflight. Set both to "ACKNOWLEDGED" after reading
# the corresponding docs.
#
# POLYMARKET_MIGRATION_ACK — verify your wallet + the markets you plan to
# trade are compatible with the post-April-2026 Polymarket USDC migration.
# See arbiter/live/README.md "Troubleshooting → Polymarket migration".
POLYMARKET_MIGRATION_ACK=<set-to-ACKNOWLEDGED-after-reading>

# OPERATOR_RUNBOOK_ACK — confirms you have read GOLIVE.md end-to-end and
# understand the safety architecture.
OPERATOR_RUNBOOK_ACK=<set-to-ACKNOWLEDGED-after-reading>


# ── Dashboard operator login + session secret ─────────────────────────────────
# OPS_EMAIL + OPS_PASSWORD are the credentials you log into /ops with.
# UI_SESSION_SECRET signs HMAC-SHA256 session tokens (7-day expiry).
#
# HOW TO OBTAIN (generate the secret locally):
#   openssl rand -hex 32
# Rotate quarterly — rotating invalidates active sessions.
#
OPS_EMAIL=<your-email>
OPS_PASSWORD=<your-strong-dashboard-password>
UI_SESSION_SECRET=<64-hex-chars-from-openssl-rand-hex-32>


# ── Observability ─────────────────────────────────────────────────────────────
ARBITER_ENV=production
ARBITER_RELEASE=phase5-first-live-trade
SENTRY_DSN=
